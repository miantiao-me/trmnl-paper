{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "types": ["node", "react"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "*.d.ts",
    "scripts/**/*.ts",
    "scripts/**/*.tsx",
    "assets/**/*.ts",
    "assets/**/*.tsx"
  ]
}
